{
  "name": "crawldeck",
  "version": "0.1.0",
  "description": "Local-first crawl job deck for fixture-backed queues, health, and crawler adapter seams.",
  "type": "module",
  "bin": {
    "crawldeck": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "fixtures",
    "README.md",
    "docs",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "test": "npm run build && node --test \"tests/**/*.test.mjs\"",
    "smoke": "npm run build && bash scripts/smoke.sh",
    "package:smoke": "npm pack --dry-run",
    "release:check": "npm run check && npm test && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "crawler",
    "local-first",
    "cli",
    "agent-tools",
    "queue"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/crawldeck.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/crawldeck/issues"
  },
  "homepage": "https://github.com/rogerchappel/crawldeck#readme"
}
